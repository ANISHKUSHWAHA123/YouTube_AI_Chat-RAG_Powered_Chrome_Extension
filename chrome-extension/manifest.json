{
  "manifest_version": 3,
  "name": "YouTube AI Chat",
  "version": "1.0",
  "description": "Chat with the transcript of the current YouTube video.",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "scripting",
    "sidePanel"
  ],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "YouTube AI Chat"
  }
}